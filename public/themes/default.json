      "dropdownOpen":    { "keyframe": "dropIn",      "duration": "180ms", "easing": "apple",  "fillMode": "both" },
      "sidebarSlide":    { "keyframe": "slideInLeft", "duration": "280ms", "easing": "apple",  "fillMode": "both" },
      "glassAppear":     { "keyframe": "glassReveal", "duration": "400ms", "easing": "apple",  "fillMode": "both" },
      "loadingSpinner":  { "keyframe": "spin",        "duration": "700ms", "easing": "linear", "iterationCount": "infinite" },
      "skeletonShimmer": { "keyframe": "shimmer",     "duration": "1800ms","easing": "linear", "iterationCount": "infinite" },
      "notifPulse":      { "keyframe": "ping",        "duration": "1200ms","easing": "linear", "iterationCount": "infinite" },
      "errorShake":      { "keyframe": "shake",       "duration": "400ms", "easing": "inOut",  "fillMode": "both" },
      "floatAnim":       { "keyframe": "float",       "duration": "3000ms","easing": "inOut",  "iterationCount": "infinite" }
    }
  },

  "transitions": {
    "default":   "all 200ms cubic-bezier(0.42, 0, 0.18, 1)",
    "fast":      "all 100ms cubic-bezier(0.42, 0, 0.18, 1)",
    "slow":      "all 350ms cubic-bezier(0.42, 0, 0.18, 1)",
    "glass":     "background 200ms ease, backdrop-filter 200ms ease, border-color 200ms ease, box-shadow 200ms ease",
    "colors":    "color 150ms ease, background-color 200ms ease, border-color 200ms ease",
    "transform": "transform 200ms cubic-bezier(0.42, 0, 0.18, 1)",
    "opacity":   "opacity 180ms ease",
    "shadow":    "box-shadow 200ms ease",
    "sidebar":   "width 280ms cubic-bezier(0.42, 0, 0.18, 1), transform 280ms cubic-bezier(0.42, 0, 0.18, 1)",
    "overlay":   "opacity 200ms ease, visibility 200ms ease"
  },

  "effects": {
    "blur": {
      "none": "0px",
      "xs":   "4px",
      "sm":   "8px",
      "md":   "16px",
      "lg":   "24px",
      "xl":   "40px",
      "2xl":  "64px",
      "3xl":  "80px"
    },
    "saturate": {
      "none":   "100%",
      "low":    "140%",
      "medium": "180%",
      "high":   "200%",
      "ultra":  "220%"
    },
    "noise": {
      "subtle": "url(\"data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E\")",
      "medium": "url(\"data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.06'/%3E%3C/svg%3E\")"
    }
  },

  "zIndex": {
    "hide":     "-1",
    "base":     "0",
    "raised":   "10",
    "dropdown": "100",
    "sticky":   "200",
    "overlay":  "300",
    "modal":    "400",
    "popover":  "500",
    "toast":    "600",
    "tooltip":  "700",
    "top":      "9999"
  },

  "icons": {
    "library":    "lucide",
    "size": {
      "xs":  "12px",
      "sm":  "16px",
      "md":  "20px",
      "lg":  "24px",
      "xl":  "32px",
      "2xl": "48px"
    },
    "strokeWidth": "1.5"
  },

  "components": {
    "button": {
      "base": {
        "borderRadius": "var(--radius-md)",
        "fontWeight":   "var(--fw-medium)",
        "transition":   "var(--transition-default)",
        "cursor":       "pointer"
      },
      "variants": {
        "primary": {
          "background":      "var(--primary-600)",
          "backgroundHover": "var(--primary-700)",
          "color":           "#ffffff",
          "boxShadow":       "var(--shadow-primary)"
        },
        "glass": {
          "background":      "var(--glass-card-bg)",
          "backdropFilter":  "var(--glass-card-blur)",
          "border":          "var(--glass-card-border)",
          "color":           "var(--surface-foreground)",
          "backgroundHover": "var(--surface-glassHover)"
        },
        "ghost": {
          "background":      "transparent",
          "backgroundHover": "var(--surface-glass)",
          "color":           "var(--surface-foreground)"
        },
        "destructive": {
          "background":      "var(--error-600)",
          "backgroundHover": "var(--error-700)",
          "color":           "#ffffff"
        }
      },
      "sizes": {
        "xs": { "height": "28px", "paddingX": "var(--space-2)", "fontSize": "var(--fs-xs)" },
        "sm": { "height": "32px", "paddingX": "var(--space-3)", "fontSize": "var(--fs-sm)" },
        "md": { "height": "40px", "paddingX": "var(--space-4)", "fontSize": "var(--fs-sm)" },
        "lg": { "height": "48px", "paddingX": "var(--space-6)", "fontSize": "var(--fs-base)" },
        "xl": { "height": "56px", "paddingX": "var(--space-8)", "fontSize": "var(--fs-lg)" }
      }
    },
    "card": {
      "base": {
        "background":    "var(--glass-card-bg)",
        "backdropFilter":"var(--glass-card-blur)",
        "border":        "var(--glass-card-border)",
        "boxShadow":     "var(--glass-card-shadow)",
        "borderRadius":  "var(--radius-xl)",
        "padding":       "var(--space-6)"
      }
    },
    "sidebar": {
      "base": {
        "background":    "var(--glass-sidebar-bg)",
        "backdropFilter":"var(--glass-sidebar-blur)",
        "border":        "var(--glass-sidebar-border)",
        "boxShadow":     "var(--glass-sidebar-shadow)"
      }
    },
    "header": {
      "base": {
        "background":    "var(--glass-header-bg)",
        "backdropFilter":"var(--glass-header-blur)",
        "border":        "var(--glass-header-border)",
        "boxShadow":     "var(--glass-header-shadow)"
      }
    },
    "modal": {
      "overlay": {
        "background":    "var(--surface-overlay)",
        "backdropFilter":"blur(12px) saturate(180%)"
      },
      "panel": {
        "background":    "var(--glass-modal-bg)",
        "backdropFilter":"var(--glass-modal-blur)",
        "border":        "var(--glass-modal-border)",
        "boxShadow":     "var(--glass-modal-shadow)",
        "borderRadius":  "var(--radius-2xl)"
      }
    },
    "input": {
      "base": {
        "background":    "var(--surface-glass)",
        "backdropFilter":"blur(12px)",
        "border":        "1px solid var(--border-input)",
        "borderRadius":  "var(--radius-md)",
        "color":         "var(--surface-foreground)",
        "transition":    "var(--transition-glass)"
      },
      "states": {
        "focus":   { "borderColor": "var(--border-focus)", "boxShadow": "0 0 0 3px rgba(99,102,241,0.20)", "background": "var(--surface-glassHover)" },
        "error":   { "borderColor": "var(--error-500)",    "boxShadow": "0 0 0 3px rgba(239,68,68,0.15)" },
        "success": { "borderColor": "var(--success-500)",  "boxShadow": "0 0 0 3px rgba(34,197,94,0.15)" }
      }
    },
    "dropdown": {
      "base": {
        "background":    "var(--glass-dropdown-bg)",
        "backdropFilter":"var(--glass-dropdown-blur)",
        "border":        "var(--glass-dropdown-border)",
        "boxShadow":     "var(--glass-dropdown-shadow)",
        "borderRadius":  "var(--radius-xl)"
      }
    },
    "toast": {
      "base": {
        "background":    "var(--glass-toast-bg)",
        "backdropFilter":"var(--glass-toast-blur)",
        "border":        "var(--glass-toast-border)",
        "boxShadow":     "var(--glass-toast-shadow)",
        "borderRadius":  "var(--radius-xl)"
      }
    }
  }
}
