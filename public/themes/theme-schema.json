      },
      "sizes": {
        "xs": { "height": "28px", "paddingX": "var(--spacing-2)",   "fontSize": "var(--font-size-xs-size)" },
        "sm": { "height": "32px", "paddingX": "var(--spacing-3)",   "fontSize": "var(--font-size-sm-size)" },
        "md": { "height": "40px", "paddingX": "var(--spacing-4)",   "fontSize": "var(--font-size-sm-size)" },
        "lg": { "height": "48px", "paddingX": "var(--spacing-6)",   "fontSize": "var(--font-size-base-size)" },
        "xl": { "height": "56px", "paddingX": "var(--spacing-8)",   "fontSize": "var(--font-size-lg-size)" }
      },
      "variants": {
        "primary": {
          "background":      "var(--primary-600)",
          "backgroundHover": "var(--primary-700)",
          "backgroundActive":"var(--primary-800)",
          "color":           "var(--surface-background)",
          "boxShadow":       "var(--shadow-sm)",
          "borderRadius":    "var(--border-radius-md)"
        },
        "secondary": {
          "background":      "var(--surface-accent)",
          "backgroundHover": "var(--neutral-200)",
          "backgroundActive":"var(--neutral-300)",
          "color":           "var(--surface-accentForeground)",
          "border":          "1px solid var(--border-default)"
        },
        "outline": {
          "background":      "transparent",
          "backgroundHover": "var(--primary-50)",
          "color":           "var(--primary-600)",
          "border":          "1px solid var(--primary-600)"
        },
        "ghost": {
          "background":      "transparent",
          "backgroundHover": "var(--neutral-100)",
          "color":           "var(--surface-foreground)"
        },
        "destructive": {
          "background":      "var(--error-600)",
          "backgroundHover": "var(--error-700)",
          "color":           "var(--surface-background)"
        },
        "success": {
          "background":      "var(--success-600)",
          "backgroundHover": "var(--success-700)",
          "color":           "var(--surface-background)"
        },
        "link": {
          "background":      "transparent",
          "color":           "var(--primary-600)",
          "textDecoration":  "underline"
        }
      },
      "animation": {
        "hover":  { "transform": "translateY(-1px)", "transition": "var(--transition-transform)" },
        "active": { "transform": "scale(0.98)",      "transition": "var(--transition-transform)" },
        "loading": { "preset": "loadingSpinner", "opacity": "0.7", "cursor": "wait" }
      }
    },

    "input": {
      "base": {
        "background":   "var(--surface-background)",
        "border":       "1px solid var(--border-input)",
        "borderRadius": "var(--border-radius-md)",
        "padding":      "var(--spacing-2) var(--spacing-3)",
        "fontSize":     "var(--font-size-sm-size)",
        "color":        "var(--surface-foreground)",
        "transition":   "var(--transition-colors)",
        "outline":      "none",
        "width":        "100%"
      },
      "states": {
        "focus":    { "borderColor": "var(--border-focus)", "boxShadow": "0 0 0 3px var(--primary-100)" },
        "error":    { "borderColor": "var(--error-500)",    "boxShadow": "0 0 0 3px var(--error-100)" },
        "success":  { "borderColor": "var(--success-500)",  "boxShadow": "0 0 0 3px var(--success-100)" },
        "disabled": { "opacity": "0.5", "cursor": "not-allowed", "background": "var(--neutral-100)" }
      },
      "sizes": {
        "sm": { "height": "32px", "fontSize": "var(--font-size-xs-size)",   "padding": "var(--spacing-1) var(--spacing-2)" },
        "md": { "height": "40px", "fontSize": "var(--font-size-sm-size)",   "padding": "var(--spacing-2) var(--spacing-3)" },
        "lg": { "height": "48px", "fontSize": "var(--font-size-base-size)", "padding": "var(--spacing-3) var(--spacing-4)" }
      },
      "animation": {
        "focus": { "keyframe": "scaleIn", "duration": "150ms", "easing": "out" }
      }
    },

    "card": {
      "base": {
        "background":   "var(--surface-card)",
        "color":        "var(--surface-cardForeground)",
        "borderRadius": "var(--border-radius-lg)",
        "boxShadow":    "var(--shadow-sm)",
        "border":       "1px solid var(--border-default)",
        "padding":      "var(--spacing-6)",
        "overflow":     "hidden"
      },
      "variants": {
        "default":   { "boxShadow": "var(--shadow-sm)" },
        "elevated":  { "boxShadow": "var(--shadow-md)" },
        "flat":      { "boxShadow": "none", "border": "1px solid var(--border-default)" },
        "ghost":     { "boxShadow": "none", "border": "none", "background": "transparent" },
        "colored":   { "background": "var(--primary-50)", "border": "1px solid var(--primary-200)" }
      },
      "animation": {
        "hover":   { "transform": "translateY(-4px)", "boxShadow": "var(--shadow-lg)", "transition": "var(--transition-default)" },
        "enter":   { "preset": "fadeIn",  "duration": "300ms", "easing": "out" },
        "visible": { "preset": "slideInUp","duration": "400ms", "easing": "spring" }
      }
    },

    "modal": {
      "overlay": {
        "background":     "var(--surface-overlay)",
        "backdropFilter": "blur(4px)"
      },
      "panel": {
        "background":   "var(--surface-card)",
        "borderRadius": "var(--border-radius-xl)",
        "boxShadow":    "var(--shadow-2xl)",
        "border":       "1px solid var(--border-default)",
        "maxWidth":     "640px",
        "width":        "100%"
      },
      "sizes": {
        "sm":   { "maxWidth": "384px" },
        "md":   { "maxWidth": "512px" },
        "lg":   { "maxWidth": "768px" },
        "xl":   { "maxWidth": "1024px" },
        "full": { "maxWidth": "100%", "borderRadius": "0" }
      },
      "animation": {
        "enter": { "preset": "modalEnter",  "duration": "200ms", "easing": "spring" },
        "exit":  { "preset": "scaleOut",    "duration": "150ms", "easing": "in" }
      }
    },

    "toast": {
      "base": {
        "borderRadius": "var(--border-radius-lg)",
        "boxShadow":    "var(--shadow-lg)",
        "padding":      "var(--spacing-4)",
        "maxWidth":     "380px",
        "border":       "1px solid var(--border-default)"
      },
      "variants": {
        "default": { "background": "var(--surface-card)",   "color": "var(--surface-foreground)" },
        "success": { "background": "var(--success-50)",     "color": "var(--success-900)",  "border": "1px solid var(--success-200)" },
        "error":   { "background": "var(--error-50)",       "color": "var(--error-900)",    "border": "1px solid var(--error-200)" },
        "warning": { "background": "var(--warning-50)",     "color": "var(--warning-900)",  "border": "1px solid var(--warning-200)" },
        "info":    { "background": "var(--info-50)",        "color": "var(--info-900)",     "border": "1px solid var(--info-200)" }
      },
      "position": "bottom-right",
      "duration": 4000,
      "animation": {
        "enter": { "preset": "toastEnter",  "duration": "300ms", "easing": "spring" },
        "exit":  { "preset": "slideInRight","duration": "200ms", "easing": "in",     "direction": "reverse" }
      }
    },

    "badge": {
      "base": {
        "borderRadius": "var(--border-radius-full)",
        "padding":      "var(--spacing-0.5) var(--spacing-2)",
        "fontSize":     "var(--font-size-xs-size)",
        "fontWeight":   "var(--font-weight-medium)"
      },
      "variants": {
        "default":   { "background": "var(--neutral-100)",  "color": "var(--neutral-800)" },
        "primary":   { "background": "var(--primary-100)",  "color": "var(--primary-800)" },
        "success":   { "background": "var(--success-100)",  "color": "var(--success-800)" },
        "warning":   { "background": "var(--warning-100)",  "color": "var(--warning-800)" },
        "error":     { "background": "var(--error-100)",    "color": "var(--error-800)" },
        "info":      { "background": "var(--info-100)",     "color": "var(--info-800)" },
        "outline":   { "background": "transparent", "border": "1px solid var(--border-default)", "color": "var(--surface-foreground)" }
      },
      "animation": {
        "pulse": { "preset": "notifPulse", "duration": "1000ms", "easing": "linear", "iterationCount": "infinite" }
      }
    },

    "table": {
      "base": {
        "width":          "100%",
        "borderCollapse": "separate",
        "borderSpacing":  "0"
      },
      "header": {
        "background":    "var(--neutral-50)",
        "color":         "var(--neutral-600)",
        "fontSize":      "var(--font-size-xs-size)",
        "fontWeight":    "var(--font-weight-semibold)",
        "letterSpacing": "var(--letter-spacing-wide)",
        "padding":       "var(--spacing-3) var(--spacing-4)",
        "textTransform": "uppercase"
      },
      "row": {
        "borderBottom":       "1px solid var(--border-divider)",
        "transition":         "var(--transition-colors)",
        "hover":              { "background": "var(--neutral-50)" },
        "selected":           { "background": "var(--primary-50)" },
        "padding":            "var(--spacing-3) var(--spacing-4)"
      },
      "animation": {
        "rowEnter": { "preset": "slideInUp", "duration": "200ms", "easing": "out", "stagger": "30ms" }
      }
    },

    "sidebar": {
      "base": {
        "background":  "var(--surface-sidebar)",
        "color":       "var(--surface-sidebarForeground)",
        "borderRight": "1px solid var(--border-default)",
        "width":       "var(--layout-sidebar-width)"
      },
      "item": {
        "borderRadius": "var(--border-radius-md)",
        "padding":      "var(--spacing-2) var(--spacing-3)",
        "fontSize":     "var(--font-size-sm-size)",
        "fontWeight":   "var(--font-weight-medium)",
        "transition":   "var(--transition-colors)",
        "active": {
          "background": "var(--primary-100)",
          "color":      "var(--primary-700)"
        },
        "hover": {
          "background": "var(--neutral-100)"
        }
      },
      "animation": {
        "collapse": { "keyframe": "slideInLeft", "duration": "250ms", "easing": "inOut", "direction": "reverse" },
        "expand":   { "keyframe": "slideInLeft", "duration": "250ms", "easing": "inOut" },
        "itemHover":{ "transform": "translateX(4px)", "transition": "var(--transition-transform)" }
      }
    },

    "dropdown": {
      "base": {
        "background":   "var(--surface-popover)",
        "border":       "1px solid var(--border-default)",
        "borderRadius": "var(--border-radius-lg)",
        "boxShadow":    "var(--shadow-lg)",
        "minWidth":     "180px",
        "padding":      "var(--spacing-1)"
      },
      "item": {
        "borderRadius": "var(--border-radius-md)",
        "padding":      "var(--spacing-2) var(--spacing-3)",
        "fontSize":     "var(--font-size-sm-size)",
        "hover":        { "background": "var(--neutral-100)" }
      },
      "animation": {
        "open":  { "preset": "dropdownOpen",  "duration": "150ms", "easing": "out" },
        "close": { "preset": "slideInDown",   "duration": "100ms", "easing": "in", "direction": "reverse" }
      }
    },

    "tabs": {
      "base": { "borderBottom": "1px solid var(--border-default)" },
      "trigger": {
        "padding":      "var(--spacing-2) var(--spacing-4)",
        "fontSize":     "var(--font-size-sm-size)",
        "fontWeight":   "var(--font-weight-medium)",
        "color":        "var(--neutral-500)",
        "transition":   "var(--transition-colors)",
        "active": {
          "color":        "var(--primary-600)",
          "borderBottom": "2px solid var(--primary-600)"
        }
      },
      "animation": {
        "indicator": { "transition": "transform 200ms cubic-bezier(0.4, 0, 0.2, 1), width 200ms cubic-bezier(0.4, 0, 0.2, 1)" },
        "content":   { "preset": "fadeIn", "duration": "200ms", "easing": "out" }
      }
    },

    "avatar": {
      "sizes": {
        "xs": { "width": "24px",  "height": "24px",  "fontSize": "var(--font-size-xs-size)" },
        "sm": { "width": "32px",  "height": "32px",  "fontSize": "var(--font-size-xs-size)" },
        "md": { "width": "40px",  "height": "40px",  "fontSize": "var(--font-size-sm-size)" },
        "lg": { "width": "48px",  "height": "48px",  "fontSize": "var(--font-size-base-size)" },
        "xl": { "width": "64px",  "height": "64px",  "fontSize": "var(--font-size-xl-size)" },
        "2xl":{ "width": "80px",  "height": "80px",  "fontSize": "var(--font-size-2xl-size)" }
      },
      "borderRadius": "var(--border-radius-full)",
      "animation": {
        "hover": { "transform": "scale(1.1)", "transition": "var(--transition-transform)" }
      }
    },

    "skeleton": {
      "base": {
        "background":         "var(--surface-skeleton)",
        "borderRadius":       "var(--border-radius-md)",
        "backgroundImage":    "linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.4) 50%, transparent 100%)",
        "backgroundSize":     "200% 100%"
      },
      "animation": {
        "shimmer": { "preset": "skeletonShimmer", "duration": "1500ms", "easing": "linear", "iterationCount": "infinite" }
      }
    },

    "tooltip": {
      "base": {
        "background":   "var(--neutral-900)",
        "color":        "var(--neutral-50)",
        "borderRadius": "var(--border-radius-md)",
        "padding":      "var(--spacing-1) var(--spacing-2)",
        "fontSize":     "var(--font-size-xs-size)",
        "maxWidth":     "200px",
        "zIndex":       "var(--z-tooltip)"
      },
      "animation": {
        "enter": { "preset": "scaleIn", "duration": "150ms", "easing": "spring" },
        "exit":  { "preset": "scaleOut","duration": "100ms", "easing": "in" }
      }
    },

    "progressBar": {
      "track": {
        "background":   "var(--neutral-100)",
        "borderRadius": "var(--border-radius-full)",
        "height":       "8px"
      },
      "fill": {
        "background":   "var(--primary-600)",
        "borderRadius": "var(--border-radius-full)",
        "transition":   "width 500ms cubic-bezier(0.4, 0, 0.2, 1)"
      },
      "variants": {
        "success":  { "background": "var(--success-500)" },
        "warning":  { "background": "var(--warning-500)" },
        "error":    { "background": "var(--error-500)" },
        "striped":  { "backgroundImage": "repeating-linear-gradient(45deg, rgba(255,255,255,0.1) 0px, rgba(255,255,255,0.1) 10px, transparent 10px, transparent 20px)" }
      },
      "animation": {
        "indeterminate": { "keyframe": "skeleton", "duration": "1500ms", "easing": "linear", "iterationCount": "infinite" }
      }
    },

    "chart": {
      "colors": [
        "var(--primary-500)",
        "var(--secondary-500)",
        "var(--success-500)",
        "var(--warning-500)",
        "var(--info-500)",
        "var(--error-500)"
      ],
      "gridColor":  "var(--border-default)",
      "textColor":  "var(--neutral-500)",
      "tooltipBackground": "var(--surface-card)",
      "animation": {
        "enter": { "duration": "600ms", "easing": "out" }
      }
    },

    "form": {
      "label": {
        "fontSize":   "var(--font-size-sm-size)",
        "fontWeight": "var(--font-weight-medium)",
        "color":      "var(--surface-foreground)",
        "marginBottom": "var(--spacing-1)"
      },
      "helper": {
        "fontSize": "var(--font-size-xs-size)",
        "color":    "var(--surface-mutedForeground)",
        "marginTop":"var(--spacing-1)"
      },
      "error": {
        "fontSize": "var(--font-size-xs-size)",
        "color":    "var(--error-500)",
        "marginTop":"var(--spacing-1)",
        "animation": { "preset": "errorShake", "duration": "400ms" }
      },
      "group": {
        "gap": "var(--spacing-4)"
      }
    }
  }
}